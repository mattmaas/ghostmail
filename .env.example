# GhostMail Configuration
# Copy this to .env and fill in your values

# Gmail OAuth2 - Get from https://console.cloud.google.com
# 1. Create project → Enable Gmail API
# 2. Credentials → OAuth2 Client ID (Desktop app)
GHOSTMAIL_GMAIL_CLIENT_ID=
GHOSTMAIL_GMAIL_CLIENT_SECRET=

# OpenCode Zen - Free MiniMax & Kimi
# Sign up at https://opencode.cn (or similar endpoint)
GHOSTMAIL_OPENCODE_API_KEY=

# DeepSeek - Cheap and powerful
# Get API key from https://platform.deepseek.com
GHOSTMAIL_DEEPSEEK_API_KEY=

# Your own Gmail address.
# Used as the daily-digest sender/recipient, and self-sent mail is excluded
# from inbox sweeps. Required for the digest; strongly recommended overall.
GHOSTMAIL_SELF_EMAIL=

# Optional: additional addresses you send from (JSON list). Also excluded
# from sweeps. Example:
# GHOSTMAIL_SELF_ALIASES='["you@work.com","alias@gmail.com"]'

# Optional: local data directory (default: ~/.ghostmail/data)
# GHOSTMAIL_DATA_DIR=

# Optional: path to a JobAuto jobs.json for cross-linking recruiter mail to
# your application records. Leave unset to disable the cross-link.
# GHOSTMAIL_JOBAUTO_JOBS_PATH=
